{
    "name": "rarksule/hashidable",
    "description": "Auto Hashids for Laravel Models and Routes",
    "type": "library",
    "license": "MIT",
    "authors": [
        {
            "name": "Suleyman Asrar",
            "email": "rarksule@gmail.com"
        }
    ],
    "require": {
        "php": ">=8.0",
        "hashids/hashids": "^4.0"
    },
    "require-dev": {
        "orchestra/testbench": "^5.3",
        "phpunit/phpunit": "^9.2",
        "orchestra/database": "^5.1"
    },
    "autoload": {
        "psr-4": {
            "rarksule\\Hashidable\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "rarksule\\Hashidable\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "rarksule\\Hashidable\\HashidableServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "phpunit --color=always"
    },
    "minimum-stability": "stable"
}
